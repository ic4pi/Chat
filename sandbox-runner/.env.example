# ---------------------------------------------------------------------------
# Vercel Sandbox credentials — pick ONE of the two auth strategies below.
# ---------------------------------------------------------------------------

# Strategy A: short-lived dev token (expires in 12 h).
# Get it by running:  vercel env pull   inside a Vercel-linked project.
# The SDK picks this up automatically; no code change needed.
VERCEL_OIDC_TOKEN=

# Strategy B: long-lived access token (recommended for a persistent server).
# 1. Team ID     — Vercel dashboard → Team Settings → General → Team ID
# 2. Project ID  — Vercel dashboard → your project → Settings → General → Project ID
# 3. Token       — Vercel dashboard → Account Settings → Tokens → Create Token
#                  (scope it to the team from step 1)
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
